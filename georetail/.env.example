# .env.example — copia este archivo como `.env` y rellena los valores reales
# Nunca subas el .env real a Git (está en .gitignore)

# ─── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/georetail
POSTGRES_PASSWORD=password
REDIS_URL=redis://localhost:6379

# ─── LLMs (modelos de lenguaje) ───────────────────────────────────────────────
# Claude Sonnet 4.6 — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GPT-4o — https://platform.openai.com
OPENAI_API_KEY=sk-...

# DeepSeek (V3.2) — https://platform.deepseek.com
DEEPSEEK_API_KEY=...

# Kimi K2.5 (Moonshot AI) — https://platform.moonshot.ai
KIMI_API_KEY=...

# Gemini 2.0 Flash — https://aistudio.google.com
GEMINI_API_KEY=...

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Una sola key vale para: Places API, Geocoding API, Static Maps API
# https://console.cloud.google.com → APIs & Services → Credenciales
GOOGLE_MAPS_API_KEY=AIza...

# ─── Reseñas ──────────────────────────────────────────────────────────────────
# Foursquare — https://developer.foursquare.com
FOURSQUARE_API_KEY=...

# Yelp — https://www.yelp.com/developers
YELP_API_KEY=...

# ─── Transporte (TMB — Metro y Bus Barcelona) ─────────────────────────────────
# https://developer.tmb.cat → crear aplicación
TMB_APP_ID=...
TMB_APP_KEY=...

# ─── Mapbox (mapa del frontend) ───────────────────────────────────────────────
# https://account.mapbox.com → Tokens
# El prefijo NEXT_PUBLIC_ hace que Next.js lo exponga al navegador
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ─── Idealista (precios de alquiler) ──────────────────────────────────────────
# Requiere solicitud de acceso: https://developers.idealista.com
# Si no tienes acceso, el pipeline de precios usará Open Data BCN como fallback
IDEALISTA_API_KEY=
IDEALISTA_SECRET=

# ─── Scraping de portales (Fotocasa, Habitaclia, Milanuncios, Pisos.com) ──────
# Sin configurar → curl_cffi (TLS fingerprinting, gratuito, funciona en la mayoría de casos)
# Con servicio → bypass garantizado para Cloudflare y anti-bots agresivos

# Servicio anti-bot: none | scrapingbee | zenrows
SCRAPING_SERVICE=none

# ScrapingBee — https://www.scrapingbee.com (desde $49/mes, 150k créditos)
# Mejor para: Cloudflare, captchas, páginas JS con renderizado
SCRAPINGBEE_API_KEY=

# ZenRows — https://www.zenrows.com (desde $49/mes, 250k peticiones)
# Mejor para: DataDome, PerimeterX, Cloudflare nivel alto
ZENROWS_API_KEY=

# Proxies propios (opcional, separados por coma)
# Formato: http://usuario:contraseña@host:puerto
# Proveedores recomendados: Bright Data (residenciales), Oxylabs, Smartproxy
SCRAPING_PROXIES=

# ─── Rutas de datos ───────────────────────────────────────────────────────────
MODELS_DIR=/data/models        # modelos XGBoost entrenados
OPTUNA_DIR=/data/optuna        # historial de búsqueda de hiperparámetros
EXPORTS_DIR=/data/exports      # PDFs generados

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=["http://localhost:3000","https://tu-dominio.com"]

# ─── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | production

# ─── Variables adicionales del backend ────────────────────────────────────────
# OpenCage (geocodificación alternativa)
OPENCAGE_API_KEY=

# Mapbox — usado también por el backend para generar mapas estáticos en PDFs
# Nota: el frontend usa NEXT_PUBLIC_MAPBOX_TOKEN (ver arriba)
MAPBOX_PUBLIC_TOKEN=pk.eyJ1...

# Sentry (monitorización de errores en producción)
SENTRY_DSN=
