# .env.example — copia este archivo como `.env` y rellena los valores reales
# Nunca subas el .env real a Git (está en .gitignore)
#
# ══════════════════════════════════════════════════════════════════════════════
#  GUÍA RÁPIDA: qué necesitas mínimo para arrancar
# ══════════════════════════════════════════════════════════════════════════════
#  LLM (pon AL MENOS una):
#    → La más recomendada para empezar: ANTHROPIC_API_KEY (Claude es el principal)
#    → La más barata para pruebas:      DEEPSEEK_API_KEY o GEMINI_API_KEY
#
#  Mapas (obligatorio para la función principal):
#    → GOOGLE_MAPS_API_KEY  (cubre Places + Geocoding + Static Maps con una sola key)
#
#  El resto son opcionales o tienen fallback gratuito.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/georetail
POSTGRES_PASSWORD=password
REDIS_URL=redis://localhost:6379

# ─── LLMs (modelos de lenguaje) ───────────────────────────────────────────────
# Cadena de fallback: Anthropic → OpenAI → DeepSeek → Kimi → Gemini
# Con una sola key funciona; el router salta al siguiente si ésta falla.

# 1. Claude Sonnet 4.6 — RECOMENDADO, el más capaz
#    Registro: https://console.anthropic.com
#    La key empieza por: sk-ant-api03-...
#    Límites plan gratuito: no hay tier gratuito, mínimo $5 de crédito
#    Límites por defecto (Tier 1): 50 req/min, 40k tokens/min
ANTHROPIC_API_KEY=sk-ant-...

# 2. GPT-4o — referencia de calidad de OpenAI
#    Registro: https://platform.openai.com/api-keys
#    La key empieza por: sk-proj-... o sk-...
#    Límites: depende del tier; Tier 1: 500 req/min, 30k tokens/min
OPENAI_API_KEY=sk-...

# 3. DeepSeek V3.2 — MUY barato (~10x más económico que OpenAI)
#    Registro: https://platform.deepseek.com → API Keys
#    La key empieza por: sk-...
#    Límites: 60 req/min en plan gratuito (con créditos iniciales)
#    NOTA: puede tener periodos de alta demanda con latencia elevada
DEEPSEEK_API_KEY=sk-...

# 4. Kimi K2.5 (Moonshot AI) — bueno en multilingüe y contexto largo
#    Registro: https://platform.moonshot.ai → API Keys
#    La key empieza por: sk-...
#    Límites: 3 req/min en tier gratuito, 60 req/min en pago
KIMI_API_KEY=sk-...

# 5. Gemini 2.0 Flash — el más rápido y barato, buena última opción
#    Registro: https://aistudio.google.com/apikey
#    La key NO tiene prefijo fijo (formato: AIza... o cadena aleatoria)
#    Límites plan gratuito: 15 req/min, 1M tokens/min — MUY generoso
#    NOTA: gemini-1.5-flash está deprecated desde noviembre 2025
GEMINI_API_KEY=...

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Una sola key vale para: Places API, Geocoding API, Static Maps API
# Registro: https://console.cloud.google.com → APIs & Services → Credenciales
# Activar las 3 APIs en el mismo proyecto de Google Cloud
# Límites: generosos en capa gratuita ($200/mes de crédito gratis)
GOOGLE_MAPS_API_KEY=AIza...

# ─── Reseñas ──────────────────────────────────────────────────────────────────
# Foursquare — https://developer.foursquare.com
# Plan gratuito: 1000 req/día
FOURSQUARE_API_KEY=...

# Yelp — https://www.yelp.com/developers
# Plan gratuito: 5000 req/día
YELP_API_KEY=...

# ─── Transporte (TMB — Metro y Bus Barcelona) ─────────────────────────────────
# https://developer.tmb.cat → crear aplicación (gratuito)
TMB_APP_ID=...
TMB_APP_KEY=...

# ─── Mapbox (mapa del frontend) ───────────────────────────────────────────────
# https://account.mapbox.com → Tokens
# El prefijo NEXT_PUBLIC_ hace que Next.js lo exponga al navegador
# Plan gratuito: 50k map loads/mes
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ─── Idealista (precios de alquiler) ──────────────────────────────────────────
# Requiere solicitud de acceso manual: https://developers.idealista.com
# Si no tienes acceso, el pipeline de precios usará Open Data BCN como fallback
IDEALISTA_API_KEY=
IDEALISTA_SECRET=

# ─── Scraping de portales (Fotocasa, Habitaclia, Milanuncios, Pisos.com) ──────
# Sin configurar → curl_cffi (TLS fingerprinting, gratuito, funciona en la mayoría de casos)
# Con servicio → bypass garantizado para Cloudflare y anti-bots agresivos

# Servicio anti-bot: none | scrapingbee | zenrows
SCRAPING_SERVICE=none

# ScrapingBee — https://www.scrapingbee.com (desde $49/mes, 150k créditos)
# Mejor para: Cloudflare, captchas, páginas JS con renderizado
SCRAPINGBEE_API_KEY=

# ZenRows — https://www.zenrows.com (desde $49/mes, 250k peticiones)
# Mejor para: DataDome, PerimeterX, Cloudflare nivel alto
ZENROWS_API_KEY=

# Proxies propios (opcional, separados por coma)
# Formato: http://usuario:contraseña@host:puerto
# Proveedores recomendados: Bright Data (residenciales), Oxylabs, Smartproxy
SCRAPING_PROXIES=

# ─── Rutas de datos ───────────────────────────────────────────────────────────
MODELS_DIR=/data/models        # modelos XGBoost entrenados
OPTUNA_DIR=/data/optuna        # historial de búsqueda de hiperparámetros
EXPORTS_DIR=/data/exports      # PDFs generados

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=["http://localhost:3000","https://tu-dominio.com"]

# ─── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | production

# ─── Variables adicionales del backend ────────────────────────────────────────
# OpenCage (geocodificación alternativa si Google Geocoding falla)
# https://opencagedata.com → plan gratuito: 2500 req/día
OPENCAGE_API_KEY=

# Mapbox — usado también por el backend para generar mapas estáticos en PDFs
# Nota: el frontend usa NEXT_PUBLIC_MAPBOX_TOKEN (ver arriba)
MAPBOX_PUBLIC_TOKEN=pk.eyJ1...

# Sentry (monitorización de errores en producción)
SENTRY_DSN=
